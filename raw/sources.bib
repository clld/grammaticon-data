@article{haspelmath_types_2023,
	title = {Types of clitics in the world’s languages},
	volume = {3},
	copyright = {Copyright (c) 2023 Martin Haspelmath},
	issn = {2785-0943},
	url = {https://typologyatcrossroads.unibo.it/article/view/16057},
	doi = {10.6092/issn.2785-0943/16057},
	abstract = {This paper offers and discusses a simple definition of the term clitic from a comparative perspective: A clitic is a bound morph that is neither an affix nor a root. It gives examples of several semantic and positional types of clitics from a wide range of languages, and it discusses some typical phonological effects associated with clitics. In the proposed definition, the crucial contrast between affixes and clitics is that affixes are class-selective (occurring always on nouns, on verbs, or on adjectives), while clitics do not exhibit word-class selectivity. In the stereotypical view of clitics, they are “prosodically deficient” in some way, but the phonological effects are quite diverse and cannot serve as a basis for a definition. As clitics are defined as kinds of minimal forms (or morphs), they cannot be nonsegmental, and they cannot interrupt another minimal form (so that there cannot be endoclitics by definition). Finally, I note that the object person indexes of the Romance languages, which have very often been called clitics, are actually affixes in the modern languages, although they must go back to earlier clitics.},
	language = {en},
	number = {2},
	urldate = {2024-01-08},
	journal = {Linguistic Typology at the Crossroads},
	author = {Haspelmath, Martin},
	year = {2023},
	keywords = {object indexing},
	pages = {1--59},
	file = {Full Text PDF:/Users/martin/Zotero/storage/KTWFZMV5/Haspelmath - 2023 - Types of clitics in the world’s languages.pdf:application/pdf},
}

@article{haspelmath_inflection_2024,
	title = {Inflection and derivation as traditional comparative concepts},
	volume = {62},
	issn = {1613-396X},
	doi = {10.1515/ling-2022-0086},
	abstract = {This article revisits the distinction between inflectional and derivational patterns in general grammar and discusses the possibility that this well-known distinction is not rooted in the reality of languages, but in the Western tradition of describing languages, through dictionaries (for words, including derived lexemes) and through grammar books (where we often find tables of exemplary paradigms). This tradition has led to rather different terminological treatments of the two kinds of patterns, but from the perspective of a constructional view of morphology, there is no need to incorporate such differences into formal grammatical descriptions. For practical purposes, we need clear and simple definitions of entrenched terms of general linguistics, so the article proposes semantically based (retro-) definitions of inflection , derivation and lexeme that cover the bulk of the existing usage. Finally, I briefly explain why we need sharp definitions of comparative concepts, and why prototype-based and fuzzy definitions of traditional terms are not helpful.},
	language = {en},
	number = {1},
	journal = {Linguistics},
	author = {Haspelmath, Martin},
	year = {2024},
	pages = {43--77},
	file = {Full Text PDF:/Users/martin/Zotero/storage/Q9UNXKR2/Haspelmath - 2024 - Inflection and derivation as traditional comparati.pdf:application/pdf},
}

@article{haspelmath_four_2024,
	title = {Four kinds of lexical items: {Words}, lexemes, inventorial items, and mental items},
